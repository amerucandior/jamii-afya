# ----------------------------------------------------------------------
# Python byte‑code, caches, virtual environments, and local config files
# ----------------------------------------------------------------------
__pycache__/
*.py[cod]          # *.pyc, *.pyo, *.pyd
*.pyo
*.pyd

# Virtual‑env directories (if you ever use a different name, add it)
.venv/
venv/
env/
ENV/

# Local environment files – keep only the template
.env
.env.*
# (real secrets stay out of the repository)

# IDE / editor artefacts
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# OS‑specific junk
.DS_Store
Thumbs.db

# Sensitive material – never commit keys / certificates
*.pem
*.key
*.crt

# Miscellaneous generated files you don't want in Git
*.log
coverage.xml
htmlcov/
dist/
build/
*.egg-info/
*.egg
.EGG-INFO/
*.whl


# node_modules – dependencies
node_modules/

# Build output
.next/
.out/
dist/
build/

# Local environment files
.env
.env.local
.env.development
.env.production

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS artefacts
.DS_Store
Thumbs.db

# IDE / editor
.idea/
.vscode/
*.code-workspace
*.suo
*.swp
